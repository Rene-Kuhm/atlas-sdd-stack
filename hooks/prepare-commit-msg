#!/usr/bin/env bash
# prepare-commit-msg — Enriquece el mensaje de commit con contexto
# Aplica solo cuando el mensaje está vacío (commit normal, no merge/rebase)

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="${2:-}"

# Solo actuar en commits normales (no merges, no squashes, no amends)
if [ -n "$COMMIT_SOURCE" ]; then
  exit 0
fi

CURRENT_MSG=$(cat "$COMMIT_MSG_FILE")

# Si ya tiene contenido (el usuario escribió algo), no sobrescribir
if [ -n "$CURRENT_MSG" ] && ! echo "$CURRENT_MSG" | grep -q "^#"; then
  exit 0
fi

# Obtener información del contexto
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | head -5)
FILE_COUNT=$(git diff --cached --name-only --diff-filter=ACM | wc -l | tr -d ' ')

# Inferir scope del branch (feat/user-auth → user-auth)
SCOPE=$(echo "$BRANCH" | sed 's|.*/||' | cut -c1-20)

# Inferir tipo del branch
TYPE=""
case "$BRANCH" in
  feat/*|feature/*)   TYPE="feat" ;;
  fix/*|bugfix/*)     TYPE="fix" ;;
  refactor/*)         TYPE="refactor" ;;
  test/*)             TYPE="test" ;;
  docs/*)             TYPE="docs" ;;
  chore/*)            TYPE="chore" ;;
  *)                  TYPE="chore" ;;
esac

# Generar template con contexto
cat > "$COMMIT_MSG_FILE" <<EOF
$TYPE($SCOPE):

# ──────────────────────────────────────────────────
# Branch: $BRANCH
# Archivos modificados ($FILE_COUNT):
$(echo "$STAGED_FILES" | sed 's/^/#   /')
# ──────────────────────────────────────────────────
# Formato: tipo(scope): descripción en imperativo
# Tipos: feat fix refactor test docs chore
#
# Ejemplos:
#   feat(auth): add JWT refresh token rotation
#   fix(api): handle null response from payment gateway
#   refactor(users): extract pagination logic to repository
EOF
